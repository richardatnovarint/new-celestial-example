---
import '../styles/global.css';
const title = "Homepage";
const description = "My Portfolio";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />

  </head>
  <body>
    <main class="el-frame-1782629827808 page" style="width:1440px;height:3600px">
      <section class="el-element-1782629862324"></section>
      <img class="el-element-1782629977166" src="data:image/svg+xml;base64," alt="image-1782629977166" loading="lazy" />
      <div class="el-component-1782630102132">
        <p class="el-text-1782630027750-kfy304e34">HOME</p>
        <p class="el-element-1782630002049">CONTACT</p>
      </div>
      <section class="el-el-1782630570287-v7b362ly3">
        <p class="el-el-1782630570288-fpm2fwo2a">My Portfolio</p>
        <p class="el-el-1782630570288-xwnocfdqj">Explore my latest work and projects</p>
